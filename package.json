{
  "name": "clearlane",
  "private": true,
  "version": "1.0.0",
  "description": "ClearLane AI — Vercel monorepo (Vite frontend + Python/MongoDB serverless API).",
  "scripts": {
    "install:all": "npm install --prefix frontend.v3",
    "dev": "npm run dev --prefix frontend.v3",
    "build": "npm run build --prefix frontend.v3",
    "preview": "npm run preview --prefix frontend.v3",
    "migrate": "python scripts/migrate_to_mongo.py",
    "vercel-build": "npm run build --prefix frontend.v3"
  },
  "engines": {
    "node": ">=18"
  }
}
