# Leave empty for same-origin "/api" (Vite proxy in dev, serverless fn in prod).
# Set an absolute URL only to point the app at a backend on another origin.
VITE_API_BASE=

# Dev-only: where the Vite proxy forwards "/api" (defaults to localhost:8000).
VITE_BACKEND_PROXY=http://localhost:8000

# MapMyIndia / Mappls map key (public, secured by domain/IP whitelist). Used as
# the static-key fallback for engine 1 (map_load) and the token for engine 2
# (Mappls v3). The app also fetches the REST key from GET /api/config at runtime;
# if both are absent the map falls back to OSM/Carto tiles (engine 3).
VITE_MAPMYINDIA_KEY=dnnjqdkukvlealrrtuvklzwjtkyoshusxdef
