# Leave empty for same-origin "/api" (Vite proxy in dev, serverless fn in prod).
# Set an absolute URL only to point the app at a backend on another origin.
VITE_API_BASE=

# Dev-only: where the Vite proxy forwards "/api" (defaults to localhost:8000).
VITE_BACKEND_PROXY=http://localhost:8000

# Optional: bake a Mappls map key into the build. If empty, the app reads it
# from GET /api/config at runtime, and falls back to Carto/OSM tiles if absent.
VITE_MAPPLS_KEY=
