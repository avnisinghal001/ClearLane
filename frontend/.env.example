# Frontend API configuration.
#
# Leave VITE_API_BASE EMPTY to use same-origin "/api" calls — this is how we
# deploy on Vercel (frontend + Python function share one origin) and how local
# dev works through the Vite proxy below. Set an absolute URL only to point the
# frontend at a backend hosted on a different origin.
VITE_API_BASE=

# Local dev only: where the Vite proxy forwards "/api" (your local backend).
VITE_BACKEND_PROXY=http://localhost:8000
