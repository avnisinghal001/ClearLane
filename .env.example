# ClearLane — backend / serverless environment variables.
# On Vercel, set these in: Project → Settings → Environment Variables.
# Locally, copy to ".env" (gitignored) and fill in.

# MongoDB connection (REQUIRED in production — Vercel's filesystem is read-only).
# Use a MongoDB Atlas SRV string. dnspython (in requirements.txt) handles +srv.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=clearlane

# Optional LLM copilot (deployment extension). Leave unset to use the
# deterministic station-briefing fallback.
# CLEARLANE_LLM=1
# ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Phase 3 — Mappls live traffic (Whitefield demo region).
# The static REST key is the PRIMARY credential for routing / matrix /
# geocode / snap APIs. OAuth fields are OPTIONAL. NEVER commit real values.
# ---------------------------------------------------------------------------
MAPPLS_REST_KEY=
MAPPLS_CLIENT_ID=
MAPPLS_CLIENT_SECRET=
MAPPLS_ACCESS_TOKEN=
